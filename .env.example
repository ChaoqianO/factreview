# Copy to .env and fill secrets locally
#   - Bash: cp .env.example .env
#   - PowerShell: Copy-Item .env.example .env

# =========================
# Fact Extraction Runtime
# =========================

# LLM runtime
# MODEL_PROVIDER controls the full review agent and shared LLM helpers.
# Use openai-codex to authenticate with a ChatGPT/Codex subscription via
# `codex login` instead of an OpenAI Platform API key.
MODEL_PROVIDER=openai
BASE_URL=
OPENAI_BASE_URL=
OPENAI_API_KEY=
API_KEY=
AGENT_MODEL=gpt-5.4
OPENAI_USE_RESPONSES_API=false
AGENT_TEMPERATURE=0.2
AGENT_MAX_TOKENS=4096
AGENT_MAX_TURNS=1000
AGENT_RESUME_ATTEMPTS=2
MAX_MARKDOWN_CHARS_TO_MODEL=120000
OPENAI_AGENTS_DISABLE_TRACING=1

# Submit behavior
SUBMIT_DEFAULT_WAIT_SECONDS=8
SUBMIT_POLL_INTERVAL_SECONDS=1
MAX_PDF_BYTES=52428800

# MinerU v4
MINERU_BASE_URL=https://mineru.net/api/v4
MINERU_API_TOKEN=
MINERU_MODEL_VERSION=vlm
MINERU_UPLOAD_ENDPOINT=/file-urls/batch
MINERU_POLL_ENDPOINT_TEMPLATES=/extract-results/batch/{batch_id},/extract-results/{batch_id},/extract/task/{batch_id}
MINERU_POLL_INTERVAL_SECONDS=3
MINERU_POLL_TIMEOUT_SECONDS=900
MINERU_ALLOW_LOCAL_FALLBACK=false

# Optional paper search/read APIs
PAPER_SEARCH_ENABLED=false
PAPER_SEARCH_BASE_URL=
PAPER_SEARCH_API_KEY=
PAPER_SEARCH_ENDPOINT=/pasa/search
PAPER_SEARCH_TIMEOUT_SECONDS=120
PAPER_SEARCH_HEALTH_ENDPOINT=/health
PAPER_SEARCH_HEALTH_TIMEOUT_SECONDS=5

PAPER_READ_BASE_URL=
PAPER_READ_API_KEY=
PAPER_READ_ENDPOINT=/read
PAPER_READ_TIMEOUT_SECONDS=180

# Semantic Scholar (Section-2 objective retrieval)
SEMANTIC_SCHOLAR_ENABLED=true
SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1
SEMANTIC_SCHOLAR_API_KEY=
SEMANTIC_SCHOLAR_TIMEOUT_SECONDS=20
SEMANTIC_SCHOLAR_TOP_K=8
S2_API_KEY=

# Finalization gates / language
ENABLE_FINAL_GATES=false
MIN_PAPER_SEARCH_CALLS_FOR_PDF_ANNOTATE=3
MIN_PAPER_SEARCH_CALLS_FOR_FINAL=3
MIN_DISTINCT_PAPER_QUERIES_FOR_FINAL=3
MIN_ANNOTATIONS_FOR_FINAL=10
MIN_ENGLISH_WORDS_FOR_FINAL=0
MIN_CHINESE_CHARS_FOR_FINAL=0
FORCE_ENGLISH_OUTPUT=true
UI_LANGUAGE=en

# PDF export defaults
PDF_FONT_NAME=Helvetica
PDF_TITLE_FONT_SIZE=15
PDF_BODY_FONT_SIZE=10
PDF_PAGE_MARGIN=48

# Teaser figure generation
TEASER_USE_GEMINI=false
GEMINI_API_KEY=
GEMINI_MODEL=google/gemini-3.1-flash-image-preview
GEMINI_BASE_URL=
GEMINI_TIMEOUT_SECONDS=60

# =========================
# Code Evaluation Runtime
# =========================

# Provider routing. Leave empty to inherit MODEL_PROVIDER.
CODE_EVAL_MODEL_PROVIDER=
CODE_EVAL_OPENAI_API_KEY=
CODE_EVAL_OPENAI_BASE_URL=
CODE_EVAL_OPENAI_MODEL=

# Optional alternative providers
CODE_EVAL_DEEPSEEK_API_KEY=
CODE_EVAL_DEEPSEEK_BASE_URL=
CODE_EVAL_DEEPSEEK_MODEL=
CODE_EVAL_QWEN_API_KEY=
CODE_EVAL_QWEN_BASE_URL=
CODE_EVAL_QWEN_MODEL=
CODE_EVAL_CLAUDE_API_KEY=
CODE_EVAL_CLAUDE_BASE_URL=
CODE_EVAL_CLAUDE_MODEL=

# Runtime behavior
CODE_EVAL_VERBOSE=1
CODE_EVAL_LLM_JUDGE_MODE=assist

# Docker execution controls
CODE_EVAL_DOCKER_SHM_SIZE=8g
CODE_EVAL_DOCKER_IPC=host
CODE_EVAL_DOCKER_GPUS=all
CODE_EVAL_DOCKER_STRATEGY=paper_image
CODE_EVAL_DOCKER_PAPER_IMAGE_PREFIX=code-eval-paper
CODE_EVAL_DOCKER_PAPER_PYTHON_IMAGE=python:3.11

# Optional dependency fallback controls
CODE_EVAL_ALLOW_TORCH_SCATTER_FALLBACK=1
CODE_EVAL_PYTHON_SPEC=
CODE_EVAL_MINERU_BACKEND=pipeline
CODE_EVAL_MINERU_DEVICE=cpu
CODE_EVAL_MINERU_SOURCE=

# =========================
# Legacy / optional provider names
# (kept for compatibility with old scripts)
# =========================
OPENAI_MODEL=gpt-5

# ChatGPT/Codex subscription backend (no Platform API key required).
# Setup:
#   1. Install Codex CLI: https://github.com/openai/codex
#   2. Run: codex login
#   3. Choose "Sign in with ChatGPT"
#   4. Set MODEL_PROVIDER=openai-codex
OPENAI_CODEX_BASE_URL=https://chatgpt.com/backend-api/codex
OPENAI_CODEX_MODEL=gpt-5.3-codex
OPENAI_CODEX_CLIENT_ID=
OPENAI_CODEX_REDIRECT_URI=http://127.0.0.1:1455/auth/callback
OPENAI_CODEX_AUTH_URL=https://auth.openai.com/oauth/authorize
OPENAI_CODEX_TOKEN_URL=https://auth.openai.com/oauth/token
OPENAI_CODEX_SCOPE=
OPENAI_CODEX_CLIENT_SECRET=
OPENAI_CODEX_NO_BROWSER=0

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-3

CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-4-sonnet
