          "transe_mult",
          "-score_func",
          "transe",
          "-opn",
          "mult",
          "-gamma",
          "9",
          "-hid_drop",
          "0.2",
          "-init_dim",
          "200"
        ],
        "timeout_sec": 86400,
        "use_conda": true,
        "artifact_paths": [
          "checkpoints/**",
          "log/**"
        ]
      },
      {
        "id": "train_transe_corr",
        "enabled": true,
        "cwd": "{paper_root}",
