{
  "mode": "full",
  "llm_used": true,
  "llm_provider": "openai-codex",
  "llm_model": "gpt-5.3-codex",
  "raw": {
    "tasks": [
      {
        "id": "smoke_help",
        "enabled": true,
        "cwd": "{paper_root}",
        "cmd": [
          "python",
          "run.py",
          "-h"
        ],
        "timeout_sec": 600,
        "use_conda": true,
        "artifact_paths": []
      },
      {
        "id": "prepare_data_extract",
        "enabled": true,
        "cwd": "{paper_root}",
        "cmd": [
          "bash",
          "preprocess.sh"
        ],
        "timeout_sec": 1200,
        "use_conda": true,
        "artifact_paths": [
          "data/**"
        ]
      },
      {
        "id": "train_transe_sub",
        "enabled": true,
        "cwd": "{paper_root}",
        "cmd": [
          "python",
          "run.py",
          "-name",
          "transe_sub",
          "-score_func",
          "transe",
          "-opn",
          "sub",
          "-gamma",
          "9",
          "-hid_drop",
          "0.1",
          "-init_dim",
          "200"
        ],
        "timeout_sec": 86400,
        "use_conda": true,
        "artifact_paths": [
          "checkpoints/**",
          "log/**"
        ]
      },
      {
        "id": "train_transe_mult",
        "enabled": true,
        "cwd": "{paper_root}",
