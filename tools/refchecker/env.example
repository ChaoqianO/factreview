# RefChecker environment example (DO NOT put real keys in this file if you plan to commit it)
#
# Copy/rename this file to `.env` (same directory as this file) and fill in your real values locally.
#
# Notes:
# - The backend loads `.env` on startup (dev convenience).
# - If you use `npm start`, changes to `.env` require a restart: `npm start -- --restart`

# Enable LLM extraction (used by CLI and for seeding a default Web UI config)
REFCHECKER_USE_LLM=true
REFCHECKER_LLM_PROVIDER=openai
REFCHECKER_LLM_MODEL=gpt-4o

# OpenAI / OpenAI-compatible gateway
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_KEY
# Optional: use a proxy / OpenAI-compatible base URL (leave empty to use OpenAI default)
OPENAI_BASE_URL=https://YOUR_OPENAI_COMPATIBLE_ENDPOINT/v1

# Optional: speeds up verification (Semantic Scholar rate limits)
SEMANTIC_SCHOLAR_API_KEY=REPLACE_WITH_YOUR_KEY


